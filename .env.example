# --- Required ---

# Postgres connection string (Neon / Supabase / Fly PG / local)
DATABASE_URL=postgres://monetizer:monetizer@localhost:5432/monetizer

# 32-byte base64 master key for credential encryption.  Generate once:
#   openssl rand -base64 32
# Losing it means re-registering every network credential. Never rotate casually.
CRED_MASTER_KEY=

# Bearer token for admin API + MCP control surface. Generate:
#   openssl rand -hex 32
ADMIN_TOKEN=

# Public base URL of the engine itself (resolve API, beacon, webhooks)
PUBLIC_BASE_URL=http://localhost:8787

# Public base URL of the click/redirect domain (can be same as PUBLIC_BASE_URL
# in dev; in prod point go.<yourdomain> at the engine)
REDIRECT_BASE_URL=http://localhost:8787

# --- Optional ---
PORT=8787
LOG_LEVEL=info
# Epsilon for exploration in the v1 decision policy (0..1)
POLICY_EPSILON=0.1
